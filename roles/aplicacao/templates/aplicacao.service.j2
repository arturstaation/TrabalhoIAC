# Serviço systemd da API — GERADO pelo Ansible (template Jinja2)
[Unit]
Description=API Trabalho IaC (Flask + SQLite)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=/usr/bin/python3 {{ app_dir }}/app.py
Restart=on-failure
User=root

[Install]
WantedBy=multi-user.target
